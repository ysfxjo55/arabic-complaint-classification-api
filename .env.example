# === Hugging Face ===
# Required. Used to download the 3 MARBERT classifiers.
HF_TOKEN=hf_your_token_here

# Optional overrides (defaults work if these repos exist & token has access)
HF_MODEL_SENTIMENT=Ysfxjo/marbert-complaint-sentiment
HF_MODEL_TOPIC=Ysfxjo/marbert-saudi-complaint-topic
HF_MODEL_ACTION=Ysfxjo/marbert-saudi-complaint-action

# === LLM explanation layer (optional) ===
# Disable to skip LLM and always return only the deterministic classification.
LLM_ENABLED=true
OPENAI_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_COMPLETION_TOKENS=512

# === Confidence guard ===
SENTIMENT_THRESHOLD=0.7
TOPIC_THRESHOLD=0.7
INTENT_THRESHOLD=0.7
ENABLE_CONFIDENCE_GUARDING=true
MANUAL_REVIEW_ON_LOW_CONFIDENCE=true

# === Operational ===
# Logs every /predict request to logs/predictions.json (best-effort).
ENABLE_PREDICTION_LOGGING=false

# Production should always be false. True = allow startup even if models fail.
ALLOW_DEGRADED_STARTUP=false

# Public demo: max successful LLM explains per IP (0 = unlimited, for local dev)
EXPLAIN_MAX_PER_IP=1
EXPLAIN_QUOTA_WINDOW_HOURS=24

# Exposes /debug/env. Keep false in production.
DEBUG_ENDPOINTS_ENABLED=false
